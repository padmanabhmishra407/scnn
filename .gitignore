# Environment variables and secrets (never commit)
.env
.env.local
.env.production
*.pem
*.key
*credentials*
*secrets*
aws_credentials.json
azure_credentials.json
gcp_service_account.json

# Database files (research data stores, not model weights)
*.db
*.sqlite3

# Docker and container artifacts (if used later)
Dockerfile.*
.docker/
docker-compose*.yml
!docker-compose.yml

# Documentation build outputs
docs/_build/
docs/html/

# Type checking cache
.pytype/

# Auto-generated files
*.generated.py
*auto*.py
generate_*.py
